# ============================================
# Backend API URL
# ============================================
# Development: http://localhost:3001
# Production: https://your-backend-domain.com
VITE_API_URL=http://localhost:3001

# true = อัปโหลดรูปเมนู (POS) ไป Google Drive ตอนกดบันทึก — เก็บใน DB เป็น gdrive:FILE_ID (ต้องเปิด GOOGLE_DRIVE_ENABLED ที่ backend)
VITE_GOOGLE_DRIVE_ENABLED=false