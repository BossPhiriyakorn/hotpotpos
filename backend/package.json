{
  "name": "hotpot-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc",
    "start": "node dist/app.js",
    "type-check": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit",
    "db:setup": "node scripts/setup-database.js",
    "db:migrate:kbank": "node scripts/migrate_kbank.js"
  },
  "dependencies": {
    "@line/bot-sdk": "^9.3.0",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "socket.io": "^4.6.1"
  },
  "overrides": {
    "tar": "^7.5.11"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
