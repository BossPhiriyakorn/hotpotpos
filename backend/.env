# ============================================
# K PAYMENT GATEWAY (KBank) Configuration
# ============================================
# โหมดการทำงาน: sandbox = ทดสอบ, production = จริง
KBANK_ENV=sandbox

# ----------------------------------------
# Sandbox (ทดสอบ) - ใส่ค่าจาก KBank API Portal Sandbox
# ----------------------------------------
KBANK_SANDBOX_BASE_URL=https://openapi-sandbox.kasikornbank.com
KBANK_SANDBOX_API_KEY=your_sandbox_api_key_here
KBANK_SANDBOX_SECRET_KEY=your_sandbox_secret_key_here
KBANK_SANDBOX_MERCHANT_ID=your_sandbox_merchant_id_here
KBANK_SANDBOX_MID=your_sandbox_mid_here

# ----------------------------------------
# Production (จริง) - ใส่ค่าหลังสมัครและได้ approval จาก KBank
# ----------------------------------------
KBANK_PRODUCTION_BASE_URL=https://openapi.kasikornbank.com
KBANK_PRODUCTION_API_KEY=your_production_api_key_here
KBANK_PRODUCTION_SECRET_KEY=your_production_secret_key_here
KBANK_PRODUCTION_MERCHANT_ID=your_production_merchant_id_here
KBANK_PRODUCTION_MID=your_production_mid_here

# ----------------------------------------
# Webhook / Callback - URL ที่ KBank จะ POST กลับเมื่อชำระสำเร็จ
# ต้องเป็น HTTPS และเข้าถึงได้จากอินเทอร์เน็ต (ตั้งในระบบ KBank ด้วย)
# ----------------------------------------
KBANK_WEBHOOK_SECRET=your_webhook_secret_here
KBANK_CALLBACK_URL=https://posproject.tectony.co.th/api/payments/kbank/callback

# ----------------------------------------
# Currency & Timeout
# ----------------------------------------
KBANK_CURRENCY=THB
KBANK_CHARGE_TIMEOUT_MINUTES=15

# ============================================
# Google Drive (Service Account — ไฟล์ JSON ไฟล์เดียว)
# ============================================
GOOGLE_DRIVE_ENABLED=true
GOOGLE_DRIVE_CREDENTIALS_PATH=../Credentials.json
# Folder ID จาก URL ของโฟลเดอร์ใน Drive (ไม่ใช่ชื่อโฟลเดอร์)
GOOGLE_DRIVE_FOLDER_ID=0AOYNTUhJOyDRUk9PVA
