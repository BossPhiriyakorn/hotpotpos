# ============================================
# Google Drive (Service Account — ไฟล์ JSON ไฟล์เดียว)
# ============================================
# ดาวน์โหลด JSON จาก Google Cloud Console → IAM → Service Account → Keys
# แชร์โฟลเดอร์ใน Drive ให้อีเมล client_email ใน JSON (สิทธิ์ Editor)
GOOGLE_DRIVE_ENABLED=false
# path สัมพัทธ์จากโฟลเดอร์ backend หรือ path เต็ม
GOOGLE_DRIVE_CREDENTIALS_PATH=./config/google-drive-service-account.json
# Folder ID จาก URL: https://drive.google.com/drive/folders/THIS_IS_FOLDER_ID
GOOGLE_DRIVE_FOLDER_ID=
# ฝั่ง frontend (โฟลเดอร์รากโปรเจกต์): ตั้ง VITE_GOOGLE_DRIVE_ENABLED=true เพื่อให้หน้า POS อัปโหลดรูปไป Drive ตอนกดบันทึก

# ============================================
# Kasikorn Open API — POS QR (OAuth + /v1/qrpayment)
# ============================================
# เมื่อครบชุด consumer + partner + MID ด้านล่าง ระบบจะใช้ Bearer token + POST /v1/qrpayment/request และ /v1/qrpayment/v4/inquiry อัตโนมัติ (ตาม Sandbox Lab)
KBANK_ENV=sandbox
KBANK_SANDBOX_BASE_URL=https://openapi-sandbox.kasikornbank.com
KBANK_PRODUCTION_BASE_URL=https://openapi.kasikornbank.com

# Developer Portal → Get Credential
KBANK_CONSUMER_ID=
KBANK_CONSUMER_SECRET=

# Partner credentials + MID บนสลิป QR (จากธนาคาร Open API Portal)
KBANK_PARTNER_ID=
KBANK_PARTNER_SECRET=
KBANK_MERCHANT_ID=

# หรือ map จากชื่อเดิม (ถ้ามีจาก Lab / เอกสารเก่า)
# KBANK_SANDBOX_MERCHANT_ID=
# KBANK_SANDBOX_SECRET_KEY=
# KBANK_SANDBOX_MID=

KBANK_CHARGE_TIMEOUT_MINUTES=15
KBANK_CURRENCY=THB
KBANK_CALLBACK_URL=
# บังคับใน NODE_ENV=production — อย่าว่างถ้ามี webhook จากธนาคาร
KBANK_WEBHOOK_SECRET=

# Sandbox: header x-test-mode + env-id (ปิดเป็น false เมื่อใช้ production URL ครบจากธนาคารและไม่ต้องการ test header)
KBANK_INCLUDE_SANDBOX_TEST_HEADERS=true
KBANK_X_TEST_MODE=true
KBANK_OAUTH_ENV_ID=OAUTH2
KBANK_QR_CREATE_ENV_ID=QR002
KBANK_QR_INQUIRY_ENV_ID=QR004

# Optional refs ใน QR body (ธนาคารอนุญาต)
# KBANK_QR_TYPE=3
# KBANK_QR_REF3_PREFIX=ORD
# KBANK_QR_REF4=HOTPOT

# บังคับใช้เส้น legacy เดิม (x-api-key + /v2/kpaymentgateway/*) เจาะเมื่อธนาคารยังให้เส้นนี้อยู่เท่านั้น
# KBANK_LEGACY_KPAY_GATEWAY=false
# KBANK_SANDBOX_API_KEY=
# KBANK_PRODUCTION_API_KEY=
