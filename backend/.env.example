# ============================================
# Google Drive (Service Account — ไฟล์ JSON ไฟล์เดียว)
# ============================================
# ดาวน์โหลด JSON จาก Google Cloud Console → IAM → Service Account → Keys
# แชร์โฟลเดอร์ใน Drive ให้อีเมล client_email ใน JSON (สิทธิ์ Editor)
GOOGLE_DRIVE_ENABLED=false
# path สัมพัทธ์จากโฟลเดอร์ backend หรือ path เต็ม
GOOGLE_DRIVE_CREDENTIALS_PATH=./config/google-drive-service-account.json
# Folder ID จาก URL: https://drive.google.com/drive/folders/THIS_IS_FOLDER_ID
GOOGLE_DRIVE_FOLDER_ID=
# ฝั่ง frontend (โฟลเดอร์รากโปรเจกต์): ตั้ง VITE_GOOGLE_DRIVE_ENABLED=true เพื่อให้หน้า POS อัปโหลดรูปไป Drive ตอนกดบันทึก
