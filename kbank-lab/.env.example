# =============================================================================
# KBank Sandbox Lab — คัดลอกเป็น .env แล้วใส่ค่าจาก Developer Portal
#   cp .env.example .env
# =============================================================================

KBANK_ENV=sandbox
KBANK_BASE_URL=https://openapi-sandbox.kasikornbank.com

# -----------------------------------------------------------------------------
# Get Credential (Consumer) — จำเป็นสำหรับ Exercise 1: OAuth 2.0
# จากเมนู "Get Credential" ใน portal:
#   CONSUMER ID     → KBANK_CONSUMER_ID
#   CONSUMER SECRET → KBANK_CONSUMER_SECRET
# ค่า ISSUED / EXPIRES ไม่ต้องใส่ใน .env (เป็นแค่วันหมดอายุของ credential)
# -----------------------------------------------------------------------------

KBANK_CONSUMER_ID=
KBANK_CONSUMER_SECRET=

# Header สำหรับโหมดทดสอบใน portal (Exercise 1)
KBANK_OAUTH_TEST_MODE=true
KBANK_OAUTH_ENV_ID=OAUTH2

# -----------------------------------------------------------------------------
# Exercise 2: Generate Thai QR — ค่าตามตาราง sandbox (ว่างไว้ใช้ default ในสคริปต)
